# =============================================================================
# Unity .gitignore
# https://github.com/github/gitignore/blob/main/Unity.gitignore
# =============================================================================

# Unity generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Ll]ocal[Cc]ache/
/[Uu]nityGenerated/

# MemoryCaptures can get excessive in size and may contain sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Asset Store Tools plugin (uncomment to ignore)
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# =============================================================================
# IDE and editor files
# =============================================================================

# Visual Studio cache directory
.vs/

# JetBrains Rider
.idea/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# =============================================================================
# Build artifacts
# =============================================================================

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.dll.mdb

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# =============================================================================
# Gradle (Android builds)
# =============================================================================

.gradle/

# =============================================================================
# OS generated files
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# Large binary / media files (recordings, videos)
# =============================================================================

# Video files
*.mp4
*.avi
*.mov
*.mkv
*.wmv

# TechSmith Camtasia / screen recording projects and recordings
*.tscproj
*.trec
*.camrec
/[Oo]ther [Dd]ocs/

# =============================================================================
# Misc
# =============================================================================

# NuGet packages (if used)
/[Pp]ackages/*/

# Plastic SCM
ignore.conf
*.private.0
*.private

# TextMesh Pro (uncomment if you want to ignore TMP examples)
# /[Aa]ssets/TextMesh Pro/Examples & Extras/
